          "min_x": 40,
          "min_y": 40,
          "max_x": 60,
          "max_y": 60
        },
        "capacity": 20
      },
      {
        "id": "market_square",
        "name": "集市场",
        "type": "zone",
        "zone_type": "market_square",
        "description": "临时搭建的摊位挤在一起，卓尔坦的矿石摊最显眼，边上还有卖干果、布匹和各色零碎的商贩。讨价还价声不绝于耳，偶尔能听到矮人的歌谣。",
        "bounds": {
          "min_x": 60,
          "min_y": 40,
          "max_x": 80,
          "max_y": 60
        },
        "capacity": 15
      },
      {
        "id": "fox_and_goose",
        "name": "狐狸与鹅酒馆",
        "type": "zone",
        "zone_type": "fox_and_goose",
        "description": "白果园最热闹的酒馆，壁炉里烧着柴火，空气中混合着麦酒和炖肉的香气。墙角的竖琴早已走音，但没人计较——酒才是正经事。泥地板上满是脚印，角落里有几个牌友正吵得面红耳赤。",
        "bounds": {
          "min_x": 20,
          "min_y": 40,
          "max_x": 40,
          "max_y": 60
        },
        "capacity": 12
      },
      {
        "id": "herb_garden",
        "name": "托蜜拉的草药园",
        "type": "zone",
        "zone_type": "herb_garden",
        "description": "托蜜拉精心打理的草药园，田埂上种满了白屈花、紫菀和甘菊。蜜蜂嗡嗡，泥土湿润。林边的木栅栏上挂着晾干的草束，几只猫在阳光下的草丛里打盹。",
        "bounds": {
          "min_x": 0,
          "min_y": 60,
          "max_x": 20,
          "max_y": 80
        },
        "capacity": 8
      },
      {
        "id": "forest",
        "name": "白果园森林",
        "type": "zone",
        "zone_type": "forest",
        "description": "茂密的白果园森林，阳光艰难地从树冠缝隙中漏下，洒在铺满落叶的地面上。林中有鹿群和狼群的踪迹，深处藏着水鬼和孽鬼的巢穴。经验丰富的猎魔人才敢独自深入。",
        "bounds": {
          "min_x": 0,
          "min_y": 0,
          "max_x": 20,
          "max_y": 20
        },
        "capacity": 10
      }
