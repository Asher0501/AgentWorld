{
  "version": "1.0",
  "description": "AgentWorld 节点配置 — 定义所有节点类型、开关、实体和世界拓扑",

  "world": {
    "default_time": {
      "hour": 8,
      "minute": 0,
      "day": 1,
      "month": 1,
      "year": 1
    },
    "allow_unregistered_entity": false,
    "zone_connections": [
      {"from": "village_square", "to": ["market", "tavern", "library", "barracks", "temple", "farm", "forest"]},
      {"from": "market",        "to": ["village_square", "farm"]},
      {"from": "tavern",        "to": ["village_square", "forest"]},
      {"from": "farm",          "to": ["village_square", "market"]},
      {"from": "forest",        "to": ["village_square", "tavern"]},
      {"from": "library",       "to": ["village_square", "temple"]},
      {"from": "temple",        "to": ["village_square", "library", "barracks"]},
      {"from": "barracks",      "to": ["village_square", "temple"]},
      {"from": "south_market",  "to": ["market"]},
      {"from": "east_tavern",   "to": ["tavern"]}
    ]
  },

  "node_types": [
    {
      "id": "npc",
      "prefix": "npc_",
      "comment": "角色节点 — BFS 全展开",
      "roles": ["actor"],
      "switches": {
        "terminal": false,
        "same_type_block": false,
        "has_recent_info": true
      },
      "prompt": {
        "category": "角色",
        "order": 2,
        "fields": ["name", "role", "mood", "satiety", "vitality", "traits", "intent"]
      },
      "properties": {
        "has_attributes": true,
        "has_inventory": true
      }
    },
    {
      "id": "zone",
      "prefix": "zone_",
      "comment": "区域节点 — 同类型阻断（zone↔zone不通）",
      "roles": ["region", "container"],
      "switches": {
        "terminal": false,
        "same_type_block": true,
        "has_recent_info": true
      },
      "prompt": {
        "category": "场所",
        "order": 1,
        "fields": ["name", "description"]
      },
      "properties": {}
    },
    {
      "id": "item",
      "prefix": "item_",
      "comment": "物品节点 — BFS 叶子节点",
      "roles": ["thing", "tradable"],
      "switches": {
        "terminal": true,
        "same_type_block": false,
        "has_recent_info": true
      },
      "prompt": {
        "category": "物品",
        "order": 3
      },
      "properties": {}
    },
    {
      "id": "object",
      "prefix": "obj_",
      "comment": "物件节点 — BFS 叶子节点，不支持 recent_info",
      "roles": ["fixture"],
      "switches": {
        "terminal": true,
        "same_type_block": false,
        "has_recent_info": false
      },
      "prompt": {
        "category": "物件",
        "order": 3
      },
      "properties": {}
    }
  ],

