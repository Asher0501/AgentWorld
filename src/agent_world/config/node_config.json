        "enabled": true,
        "description": "校验操作中的 src/tgt 是否在标签映射表中"
      },
      "capacity_upper_bound": {
        "type": "dead_code",
        "code": 2,
        "enabled": true,
        "description": "校验 delta 输出量不超过边当前 qty"
      },
      "degree_conservation": {
        "type": "dead_code",
        "code": 5,
        "enabled": true,
        "description": "校验每个 group 内每种 item 的 delta 之和为 0"
      },
      "direction_pairing": {
        "type": "llm_batch",
        "code": 3,
        "enabled": false,
        "description": "LLM 校验双向交换中标签流向是否交替"
      },
      "story_consistency": {
        "type": "llm_batch",
        "code": 4,
        "enabled": false,
        "description": "LLM 校验操作方向与故事描述是否一致"
      }
    }
